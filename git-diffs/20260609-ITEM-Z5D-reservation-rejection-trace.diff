+CREATE TABLE IF NOT EXISTS reservation_rejection_events (
+  id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
+  company_id BIGINT UNSIGNED NULL,
+  branch_id BIGINT UNSIGNED NULL,
+  user_id BIGINT UNSIGNED NULL,
