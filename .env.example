# Control Ropa local environment template
# Copy to .env or configure these variables in your shell/CI secret store.
# Do not commit real secrets.

# Frontend API routing
EXPO_PUBLIC_API_PORT=8090
EXPO_PUBLIC_API_HOST=192.168.0.128
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8090

# Backend server
CONTROL_ROPA_SERVER_PORT=8090

# Backend datasource
CONTROL_ROPA_DB_URL=jdbc:mysql://localhost:3306/control_ropa?useSSL=false&serverTimezone=America/Mexico_City&allowPublicKeyRetrieval=true
CONTROL_ROPA_DB_USERNAME=root
CONTROL_ROPA_DB_PASSWORD=change-me

# Security audit
SECURITY_AUDIT_RETENTION_DAYS=180
SECURITY_AUDIT_CLEANUP_ENABLED=true
SECURITY_AUDIT_CLEANUP_CRON=0 0 3 * * *

# Backend logs
CONTROL_ROPA_LOG_FILE=C:/HPSQ-SOFT/control-ropa/logs/backend/control-ropa.log
CONTROL_ROPA_LOG_PATTERN=C:/HPSQ-SOFT/control-ropa/logs/backend/control-ropa.%d{yyyy-MM-dd}.%i.log.gz
CONTROL_ROPA_LOG_MAX_FILE_SIZE=20MB
CONTROL_ROPA_LOG_MAX_HISTORY=30
CONTROL_ROPA_LOG_TOTAL_SIZE_CAP=1GB
